.DS_Store

# .NET Functions API build output
api/bin/
api/obj/

# Local Functions settings (never publish)
api/local.settings.json

# Poller Functions build output + local settings
poller/bin/
poller/obj/
poller/local.settings.json

# Shared feeds library build output
feeds/bin/
feeds/obj/

# Test project build output
tests/*/bin/
tests/*/obj/

# Browser CloudKit configuration (tokens are origin-restricted but must never
# be copied from the local spike into source control).
config.local.json
config.*.local.json
scripts/companion/config.local.js
