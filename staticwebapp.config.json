{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "routes": [
    { "route": "/poller/*", "statusCode": 404 },
    { "route": "/episode", "rewrite": "/api/episode" },
    { "route": "/show", "rewrite": "/api/show" },
    { "route": "/.well-known/apple-app-site-association", "rewrite": "/.well-known/apple-app-site-association.json" }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/.well-known/*",
      "/assets/*",
      "/*.css",
      "/*.js",
      "/*.png",
      "/*.svg",
      "/*.ico"
    ]
  },
  "platform": {
    "apiRuntime": "dotnet-isolated:9.0"
  },
  "mimeTypes": {
    ".": "application/json"
  },
  "responseOverrides": {
    "404": { "rewrite": "/index.html" }
  }
}
